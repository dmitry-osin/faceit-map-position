{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "default_locale": "en",
  "version": "1.1.0",
  "author": "Dmitry Osin",
  "homepage_url": "https://github.com/dmitry-osin/faceit-map-position",
  "description": "__MSG_extDescription__",
  "permissions": ["storage"],
  "host_permissions": ["https://www.faceit.com/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "__MSG_extTitle__"
  },
  "content_scripts": [
    {
      "matches": ["https://www.faceit.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
